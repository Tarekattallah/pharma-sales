                <mxCell id="75" value="&lt;h1 data-end=&quot;152&quot; data-start=&quot;122&quot; data-section-id=&quot;1oh0srm&quot;&gt;1️⃣ Files &amp;amp; Responsibilities&lt;/h1&gt;&lt;br/&gt;&lt;div class=&quot;TyagGW_tableContainer&quot;&gt;&lt;div class=&quot;group TyagGW_tableWrapper flex flex-col-reverse w-fit&quot; tabindex=&quot;-1&quot;&gt;&lt;table class=&quot;w-fit min-w-(--thread-content-width)&quot; data-end=&quot;876&quot; data-start=&quot;154&quot;&gt;&lt;thead data-end=&quot;183&quot; data-start=&quot;154&quot;&gt;&lt;tr data-end=&quot;183&quot; data-start=&quot;154&quot;&gt;&lt;th class=&quot;&quot; data-col-size=&quot;sm&quot; data-end=&quot;161&quot; data-start=&quot;154&quot;&gt;File&lt;/th&gt;&lt;th class=&quot;&quot; data-col-size=&quot;lg&quot; data-end=&quot;183&quot; data-start=&quot;161&quot;&gt;Job (Easy English)&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-end=&quot;876&quot; data-start=&quot;212&quot;&gt;&lt;tr data-end=&quot;318&quot; data-start=&quot;212&quot;&gt;&lt;td data-col-size=&quot;sm&quot; data-end=&quot;230&quot; data-start=&quot;212&quot;&gt;&lt;code data-end=&quot;229&quot; data-start=&quot;214&quot;&gt;user.model.js&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;lg&quot; data-end=&quot;318&quot; data-start=&quot;230&quot;&gt;Defines &lt;strong data-end=&quot;258&quot; data-start=&quot;240&quot;&gt;user structure&lt;/strong&gt; in database (fields, types, roles, managerId, timestamps)&lt;/td&gt;&lt;/tr&gt;&lt;tr data-end=&quot;411&quot; data-start=&quot;319&quot;&gt;&lt;td data-col-size=&quot;sm&quot; data-end=&quot;342&quot; data-start=&quot;319&quot;&gt;&lt;code data-end=&quot;341&quot; data-start=&quot;321&quot;&gt;user.validation.js&lt;/code&gt;&lt;/td&gt;&lt;td data-end=&quot;411&quot; data-start=&quot;342&quot; data-col-size=&quot;lg&quot;&gt;Checks &lt;strong data-end=&quot;365&quot; data-start=&quot;351&quot;&gt;input data&lt;/strong&gt; before saving (name, email, password, role)&lt;/td&gt;&lt;/tr&gt;&lt;tr data-end=&quot;552&quot; data-start=&quot;412&quot;&gt;&lt;td data-col-size=&quot;sm&quot; data-end=&quot;432&quot; data-start=&quot;412&quot;&gt;&lt;code data-end=&quot;431&quot; data-start=&quot;414&quot;&gt;user.service.js&lt;/code&gt;&lt;/td&gt;&lt;td data-end=&quot;552&quot; data-start=&quot;432&quot; data-col-size=&quot;lg&quot;&gt;Main &lt;strong data-end=&quot;456&quot; data-start=&quot;439&quot;&gt;logic with DB&lt;/strong&gt;: create, get, update, delete users; uses &lt;strong data-end=&quot;513&quot; data-start=&quot;498&quot;&gt;APIFeatures&lt;/strong&gt; for filtering/search/sort/pagination&lt;/td&gt;&lt;/tr&gt;&lt;tr data-end=&quot;668&quot; data-start=&quot;553&quot;&gt;&lt;td data-col-size=&quot;sm&quot; data-end=&quot;576&quot; data-start=&quot;553&quot;&gt;&lt;code data-end=&quot;575&quot; data-start=&quot;555&quot;&gt;user.controller.js&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;lg&quot; data-end=&quot;668&quot; data-start=&quot;576&quot;&gt;Handles &lt;strong data-end=&quot;602&quot; data-start=&quot;586&quot;&gt;API requests&lt;/strong&gt;: calls service functions, validates data, returns JSON response&lt;/td&gt;&lt;/tr&gt;&lt;tr data-end=&quot;765&quot; data-start=&quot;669&quot;&gt;&lt;td data-col-size=&quot;sm&quot; data-end=&quot;688&quot; data-start=&quot;669&quot;&gt;&lt;code data-end=&quot;687&quot; data-start=&quot;671&quot;&gt;user.routes.js&lt;/code&gt;&lt;/td&gt;&lt;td data-end=&quot;765&quot; data-start=&quot;688&quot; data-col-size=&quot;lg&quot;&gt;Defines &lt;strong data-end=&quot;715&quot; data-start=&quot;698&quot;&gt;API endpoints&lt;/strong&gt; (&lt;code data-end=&quot;730&quot; data-start=&quot;717&quot;&gt;POST /users&lt;/code&gt;, &lt;code data-end=&quot;744&quot; data-start=&quot;732&quot;&gt;GET /users&lt;/code&gt;, &lt;code data-end=&quot;762&quot; data-start=&quot;746&quot;&gt;GET /users/:id&lt;/code&gt;)&lt;/td&gt;&lt;/tr&gt;&lt;tr data-end=&quot;876&quot; data-start=&quot;766&quot;&gt;&lt;td data-col-size=&quot;sm&quot; data-end=&quot;791&quot; data-start=&quot;766&quot;&gt;&lt;code data-end=&quot;790&quot; data-start=&quot;768&quot;&gt;utils/apiFeatures.js&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;lg&quot; data-end=&quot;876&quot; data-start=&quot;791&quot;&gt;Helper class: &lt;strong data-end=&quot;854&quot; data-start=&quot;807&quot;&gt;filter, search, sort, limitFields, paginate&lt;/strong&gt;; used in &lt;code data-end=&quot;874&quot; data-start=&quot;864&quot;&gt;getUsers&lt;/code&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
